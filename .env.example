# ───────────────────────────────────────────────────────────────
# Domaine des Élégances — template des variables d'environnement
# ───────────────────────────────────────────────────────────────
# Copier ce fichier en .env.local et remplir les valeurs réelles.
# .env.local est dans .gitignore — il ne sera jamais commité.
#
# Où trouver les valeurs :
#   Supabase → Settings → API
#   · Project URL       → NEXT_PUBLIC_SUPABASE_URL
#   · anon / public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   ⚠️ Ne jamais copier la service_role key ici.
# ───────────────────────────────────────────────────────────────

# Projet Supabase (URL + clé anon publique uniquement)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL publique du site (localhost en dev, domaine réel en prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
